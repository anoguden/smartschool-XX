<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Smartschool Thema's</title>
  <style>
    /* ── Reset & basis ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --accent: #6c63ff;
      --bg: #12121a;
      --surface: #1e1e2e;
      --surface2: #2a2a3e;
      --text: #e0e0f0;
      --text-muted: #888aaa;
      --radius: 10px;
      --transition: 0.2s ease;
    }

    body {
      width: 320px;
      background: var(--bg);
      color: var(--text);
      font-family: 'Segoe UI', system-ui, sans-serif;
      font-size: 14px;
      padding: 0 0 16px;
      user-select: none;
    }

    /* ── Header ── */
    header {
      background: linear-gradient(135deg, #6c63ff 0%, #3ecfcf 100%);
      padding: 16px 18px 14px;
    }
    header h1 {
      font-size: 16px;
      font-weight: 700;
      letter-spacing: 0.3px;
    }
    header p {
      font-size: 11px;
      opacity: 0.85;
      margin-top: 2px;
    }

    /* ── Secties ── */
    section {
      padding: 14px 16px 0;
    }
    section + section {
      border-top: 1px solid var(--surface2);
      margin-top: 14px;
      padding-top: 14px;
    }

    .section-title {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.8px;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 10px;
    }

    /* ── Thema-kaarten ── */
    .themes-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }

    .theme-card {
      border: 2px solid transparent;
      border-radius: var(--radius);
      overflow: hidden;
      cursor: pointer;
      transition: border-color var(--transition), transform var(--transition);
      background: var(--surface);
    }
    .theme-card:hover { transform: translateY(-2px); }
    .theme-card.active { border-color: var(--accent); }

    .theme-preview {
      height: 52px;
      position: relative;
    }
    /* Dark Mode preview */
    .preview-dark { background: linear-gradient(135deg, #0f0f1a 50%, #1a1a2e 100%); }
    /* Ocean preview */
    .preview-ocean { background: linear-gradient(135deg, #0a2342 50%, #1565c0 100%); }
    /* Sunset preview */
    .preview-sunset { background: linear-gradient(135deg, #ff6b35 50%, #f7c59f 100%); }

    .theme-preview::after {
      content: '';
      position: absolute;
      left: 6px; bottom: 6px;
      width: 55%; height: 6px;
      border-radius: 3px;
      background: rgba(255,255,255,0.15);
    }

    .theme-label {
      padding: 5px 6px 6px;
      font-size: 11px;
      font-weight: 600;
      text-align: center;
      color: var(--text-muted);
    }
    .theme-card.active .theme-label { color: var(--accent); }

    /* ── Upload sectie ── */
    .upload-area {
      border: 2px dashed var(--surface2);
      border-radius: var(--radius);
      padding: 14px;
      text-align: center;
      cursor: pointer;
      transition: border-color var(--transition), background var(--transition);
    }
    .upload-area:hover {
      border-color: var(--accent);
      background: rgba(108,99,255,0.05);
    }
    .upload-area .icon { font-size: 22px; margin-bottom: 4px; }
    .upload-area p { font-size: 12px; color: var(--text-muted); line-height: 1.4; }
    .upload-area strong { color: var(--text); }

    #fileInput { display: none; }

    /* Thumbnail na upload */
    #uploadPreview {
      display: none;
      margin-top: 10px;
      border-radius: var(--radius);
      overflow: hidden;
      position: relative;
    }
    #uploadPreview img {
      width: 100%;
      height: 80px;
      object-fit: cover;
      display: block;
    }
    #removeUpload {
      position: absolute;
      top: 5px; right: 5px;
      background: rgba(0,0,0,0.6);
      border: none;
      color: #fff;
      border-radius: 50%;
      width: 22px; height: 22px;
      font-size: 12px;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
    }

    /* Kleur-overlay toggle */
    .option-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: 10px;
    }
    .option-row label { font-size: 12px; color: var(--text-muted); }

    /* Toggle switch */
    .toggle { position: relative; display: inline-block; width: 36px; height: 20px; }
    .toggle input { opacity: 0; width: 0; height: 0; }
    .slider {
      position: absolute; inset: 0;
      background: var(--surface2);
      border-radius: 20px;
      cursor: pointer;
      transition: background var(--transition);
    }
    .slider::before {
      content: '';
      position: absolute;
      left: 3px; top: 3px;
      width: 14px; height: 14px;
      border-radius: 50%;
      background: #fff;
      transition: transform var(--transition);
    }
    .toggle input:checked + .slider { background: var(--accent); }
    .toggle input:checked + .slider::before { transform: translateX(16px); }

    /* ── Reset knop ── */
    #resetBtn {
      width: calc(100% - 32px);
      margin: 14px 16px 0;
      padding: 9px;
      background: var(--surface2);
      color: var(--text-muted);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: var(--radius);
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      transition: background var(--transition), color var(--transition);
    }
    #resetBtn:hover { background: #3a1a1a; color: #ff6b6b; }

    /* ── Status-bericht ── */
    #statusMsg {
      text-align: center;
      font-size: 11px;
      color: #3ecfcf;
      margin-top: 10px;
      min-height: 16px;
      opacity: 0;
      transition: opacity 0.3s;
    }
    #statusMsg.visible { opacity: 1; }

    /* ─────────────────────────────────────────────
       TODO: GAMES-SECTIE
       Voeg hieronder een nieuwe <section> toe met
       id="games-section" voor de spel-knoppen/links.
       Voorbeeld:
       <section id="games-section">
         <p class="section-title">Mini-Games</p>
         ...
       </section>
    ───────────────────────────────────────────── */
  </style>
</head>
<body>

  <header>
    <h1>🎨 Smartschool Thema's</h1>
    <p>Personaliseer jouw Smartschool-omgeving</p>
  </header>

  <!-- ── Thema keuze ── -->
  <section>
    <p class="section-title">Vooraf ingestelde thema's</p>
    <div class="themes-grid">

      <div class="theme-card" data-theme="dark">
        <div class="theme-preview preview-dark"></div>
        <p class="theme-label">Dark Mode</p>
      </div>

      <div class="theme-card" data-theme="ocean">
        <div class="theme-preview preview-ocean"></div>
        <p class="theme-label">Ocean</p>
      </div>

      <div class="theme-card" data-theme="sunset">
        <div class="theme-preview preview-sunset"></div>
        <p class="theme-label">Sunset</p>
      </div>

    </div>
  </section>

  <!-- ── Eigen achtergrond upload ── -->
  <section>
    <p class="section-title">Eigen achtergrond</p>

    <div class="upload-area" id="uploadArea">
      <div class="icon">🖼️</div>
      <p><strong>Klik om een afbeelding te kiezen</strong><br>JPG, PNG of WebP — max. 5 MB</p>
    </div>
    <input type="file" id="fileInput" accept="image/jpeg,image/png,image/webp" />

    <div id="uploadPreview">
      <img id="previewImg" src="" alt="Voorvertoning" />
      <button id="removeUpload" title="Verwijder">✕</button>
    </div>

    <!-- Automatische kleuroverlay toggle -->
    <div class="option-row">
      <label for="overlayToggle">Auto kleuren-overlay</label>
      <label class="toggle">
        <input type="checkbox" id="overlayToggle" checked />
        <span class="slider"></span>
      </label>
    </div>
  </section>

  <!-- ── Reset ── -->
  <button id="resetBtn">↺ Verwijder alle aanpassingen</button>

  <div id="statusMsg"></div>

  <!-- TODO: GAMES-SECTIE — voeg hier de HTML toe (zie CSS-commentaar hierboven) -->

  <script src="popup.js"></script>
</body>
</html>
